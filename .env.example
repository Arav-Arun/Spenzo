# Copy this file to '.env' and fill in your actual API keys.

# 1. Supabase
# Get these from your Supabase Project Settings > API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-supabase-service-role-key"

# 2. OpenAI
# Required for natural language parsing and receipt vision
OPENAI_API_KEY="sk-proj-your-openai-api-key"

# 3. Twilio (WhatsApp Webhook Configuration)
# Get these from your Twilio Console > Account Info
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# 4. Web3 APIs (Required for advanced crypto features)
# Alchemy: Ethereum/Polygon RPC | Helius: Solana RPC
ALCHEMY_API_KEY="your-alchemy-api-key"
HELIUS_API_KEY="your-helius-api-key"
